<Page
    x:Class="UAV_Assistive_Operation.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:UAV_Assistive_Operation.Converters" 
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">


    <Page.Resources>
        <converters:EventTypeToColorConverter x:Key="EventTypeToColorConverter"/>
    </Page.Resources>
    
    <Grid Background="LightGray">
        <!--Defining columns-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!--Defining rows-->
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!--UAV map-->
        <Grid x:Name="MapContainer" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
            <WebView
            x:Name="MapView"
            VerticalAlignment="Stretch"
            d:Source="about:blank"
            d:DesignWidth="800"
            d:DesignHeight="600"
            d:DefaultBackgroundColor="Gray" />

            <Grid x:Name="MapFallback" Background="DarkGray">
                <TextBlock 
                    Text="Map Service Unavailable"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"/>
            </Grid>
        </Grid>

        <!--Top bar overlay-->
        <Grid x:Name="AlertGrid"  Grid.Row="0" Grid.ColumnSpan="2" Height="56">
            <Grid.Background>
                <LinearGradientBrush x:Name="AlertBackground" StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="SlateGray" Offset="0.0"/>
                    <GradientStop Color="SlateGray" Offset="0.48"/>
                    <GradientStop Color="#002F4F4F" Offset="0.65"/>
                    <GradientStop Color="#002F4F4F" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Menu Icon-->
            <Image 
                x:Name="MenuIcon"
                Grid.Column="0"
                Margin="11"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" 
                Source="Assets/MenuLogoWhite.png" 
                Stretch="Uniform" 
                Opacity="1"/>

            <!--Divider-->
            <Line 
                Grid.ColumnSpan="2" 
                X1="56" Y1="8" 
                X2="56" Y2="48" 
                Stroke="White" 
                StrokeThickness="1"/>

            <!--Flight warnings-->
            <TextBlock 
                Grid.Column="1" 
                VerticalAlignment="Center"
                Padding="15" 
                Text="{Binding Alerts.DisplayMessage}" 
                Foreground="White" 
                FontWeight="SemiBold" 
                FontSize="18"/>
        </Grid>

        <!--Left panel-->
        <Grid Grid.Row="1" Grid.Column="0" Padding="12, 7" RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="0.8*"/>
                <RowDefinition Height="1.6*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!--UAV Status-->
            <StackPanel Grid.Row="0" Padding="8">
                <TextBlock
                    Text="UAV Status"
                    HorizontalAlignment="Center"
                    TextDecorations="Underline"
                    FontSize="22"
                    FontWeight="Bold" />
            </StackPanel>

            <StackPanel Grid.Row="1" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--Flight Mode-->
                    <TextBlock 
                        Grid.Row="0" 
                        Grid.Column="0" 
                        Text="Flight Mode:"
                        FontSize="18"
                        FontWeight="SemiBold" />
                    <TextBlock 
                        Grid.Row="0" 
                        Grid.Column="1" 
                        Padding="20,0,0,10"
                        Text="{Binding Telemetry.FlightMode.DisplayText}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Left" />

                    <!--Connection-->
                    <TextBlock 
                        Grid.Row="1" 
                        Grid.Column="0" 
                        Text="GPS Connection:"
                        FontSize="18"
                        FontWeight="SemiBold"/>
                    <TextBlock 
                        Grid.Row="1" 
                        Grid.Column="1" 
                        Padding="20,0,0,10"
                        Text="{Binding Telemetry.GPS.DisplayText}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Left"/>
                </Grid>

            </StackPanel>

            <!--Telemetry-->
            <Border 
                Grid.Row="2" 
                Background="LightGray"
                Margin="20,0" 
                Padding="10" 
                CornerRadius="20" 
                BorderBrush="Black" 
                BorderThickness="2">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock 
                        Grid.Column="0"
                        Grid.Row="0"
                        Text="{Binding Telemetry.Battery.DisplayText}"
                        FontSize="16"
                        HorizontalAlignment="Center"/>
                        
                    <TextBlock 
                        Grid.Column="1"
                        Grid.Row="0"
                        Text="{Binding Telemetry.Altitude.DisplayText}"
                        FontSize="16"
                        HorizontalAlignment="Center"/>

                    <TextBlock 
                        Grid.Column="0"
                        Grid.Row="1"
                        Margin="0,3,0,0"
                        Text="{Binding Telemetry.Speed.DisplayHorizontal}"
                        FontSize="16"
                        FontStyle="Italic"
                        HorizontalAlignment="Center"/>
    
                    <TextBlock 
                        Grid.Column="1"
                        Grid.Row="1"
                        Margin="0,3,0,0"
                        Text="{Binding Telemetry.Speed.DisplayVertical}"
                        FontSize="16"
                        FontStyle="Italic"
                        HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!--Divider-->
            <Line 
                Grid.Row="3"
                X1="0" Y1="0"
                X2="1" Y2="0"
                Margin="100,10,100,0"
                Stroke="Black"
                StrokeThickness="2"
                Stretch="Fill"
                VerticalAlignment="Stretch"/>

            <!--Flight Commands=-->
            <Border Grid.Row="4" Background="LightGray" Padding="8">
                <StackPanel>
                    <TextBlock
                        Padding="0,0,0,20"
                        Text="Flight Commands"
                        HorizontalAlignment="Center"
                        TextDecorations="Underline"
                        FontSize="22"
                        FontWeight="Bold" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="Take off"
                            FontSize="18"
                            HorizontalAlignment="Center"/>
                        <Rectangle 
                            Grid.Column="1" 
                            Width="1"
                            Fill="Black"
                            VerticalAlignment="Stretch"/>
                        <TextBlock
                            Grid.Column="2"
                            Text="Land"
                            FontSize="18"
                            HorizontalAlignment="Center"/>
                        <Rectangle
                            Grid.Column="3" 
                            Width="1"
                            Fill="Black"
                            VerticalAlignment="Stretch"/>
                        <TextBlock
                            Grid.Column="4"
                            Text="Stop"
                            FontSize="18"
                            HorizontalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

        </Grid>

        <Border 
            Grid.Row="2"
            Grid.ColumnSpan="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="SlateGray" Offset="0.0"/>
                            <GradientStop Color="SlateGray" Offset="0.48"/>
                            <GradientStop Color="AliceBlue" Offset="0.65"/>
                            <GradientStop Color="AliceBlue" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <TextBlock
                        Padding="20,0,0,0"
                        VerticalAlignment="Center"
                        Text="Event Log:"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="SemiBold"/>
                </Grid>

                <!-- Log content -->
                <ListView 
                    x:Name="EventLogList"
                    Grid.Row="1"
                    ItemsSource="{Binding EventLog}"
                    Background="AliceBlue"
                    Padding="10,4"
                    BorderThickness="0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionMode="None"
                    VerticalAlignment="Stretch">

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel VerticalAlignment="Bottom" 
                             ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="15,4"/>
                            <Setter Property="MinHeight" Value="0"/>

                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Setter Property="IsTabStop" Value="False"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Log entry row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding TimeDisplay}"
                                        FontSize="16"
                                        Foreground="DimGray"
                                        Margin="0,0,80,0" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding EventType}"
                                        FontSize="16" 
                                        Foreground="{Binding EventType, Converter={StaticResource EventTypeToColorConverter}}"/>

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding Message}"
                                        FontSize="16"
                                        TextWrapping="Wrap" />
                                </Grid>

                                <!-- Divider -->
                                <Border 
                                    Height="1"
                                    Background="#55000000"
                                    Margin="0,5,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

<Page
    x:Class="UAV_Assistive_Operation.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:UAV_Assistive_Operation.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">


    <Page.Resources>
        <converters:EventTypeToColorConverter x:Key="EventTypeToColorConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="LightGray">
        <!--Defining columns-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!--Defining rows-->
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!--Initial Controller Connection Popup-->
        <ContentDialog
            x:Name="ControllerRequiredPopup"
            Title="Controller Disconnected"
            PrimaryButtonText="Waiting for controller…"
            IsPrimaryButtonEnabled="False"
            CloseButtonText=""
            DefaultButton="Primary">

            <StackPanel Spacing="12">
                <TextBlock
                    Text="Please connect a controller to continue."
                    TextWrapping="Wrap" />

                <ProgressRing
                    IsActive="True"
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </ContentDialog>

        <!--Controller Remapping Popup-->
        <ContentDialog
            x:Name="ControllerRemappingPopup"
            Padding="0"
            Title="Controller Configurator"
            PrimaryButtonText=""
            CloseButtonText=""
            IsPrimaryButtonEnabled="False"
            DefaultButton="None"
            Width="720">

            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <ScrollViewer
                    x:Name="RemapScrollViewer"
                    Grid.Row="0"
                    VerticalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Hidden">
                    
                    <StackPanel>
                        <TextBlock
                        Margin="0,0,0,15"
                        Text="Controller configuration can be modified in the menu."
                        TextWrapping="Wrap"
                        Opacity="0.6" />

                        <ItemsControl x:Name="RemapItemsControl" ItemsSource="{x:Bind ViewModel.ControllerConfiguration.RemapRows, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <!--Control Row Template-->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid ColumnSpacing="12">

                                            <Border
                                            Background="#FFE0E0E0"
                                            CornerRadius="10"
                                            Padding="22"
                                            Grid.ColumnSpan="2"
                                            Visibility="{Binding IsHighlighted, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <Grid ColumnSpacing="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="1.3*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                Text="{Binding DisplayName}"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center" />

                                                <TextBox
                                                Grid.Column="1"
                                                IsReadOnly="True"
                                                IsTabStop="False"
                                                Width="150"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Text="{Binding AssignedInput}"
                                                PlaceholderText="Waiting for input..."
                                                BorderBrush="SlateGray"
                                                CornerRadius="8" />
                                            </Grid>
                                        </Grid>
                                        <Border 
                                        Grid.Row="1"
                                        Height="1"
                                        Background="#55000000"
                                        Margin="10,0,200,2"
                                        Visibility="{Binding IsHighlighted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />

                                        <TextBlock
                                        Grid.Row="2"
                                        Text="{Binding Error}"
                                        Foreground="Red"
                                        FontSize="12"
                                        Margin="8,2,8,0"
                                        Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!--Progress bar-->
                <StackPanel Grid.Row="1" Spacing="8" Margin="0,12,0,0">
                    <TextBlock
                        x:Name="RemapProgressText"
                        Text="Setting inputs..."
                        HorizontalAlignment="Center"
                        Visibility="Collapsed" />

                    <ProgressBar
                        x:Name="RemapProgressBar"
                        IsIndeterminate="True"
                        Height="6"
                        Margin="10,0"
                        Visibility="Collapsed" />
                </StackPanel>
            </Grid>

        </ContentDialog>

        <!--Initial UAV Connection Popup-->
        <ContentDialog
            x:Name="AircraftRequiredPopup"
            Title="Aircraft Disconnected"
            PrimaryButtonText="Waiting for aircraft…"
            IsPrimaryButtonEnabled="False"
            CloseButtonText=""
            DefaultButton="Primary">

            <StackPanel Spacing="12">
                <TextBlock
                    Text="Please connect an aircraft to continue."
                    TextWrapping="Wrap" />

                <ProgressRing
                    IsActive="True"
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </ContentDialog>

        <!--Menu Popup-->
        <ContentDialog
            x:Name="MenuPopup"
            Title="Menu"
            PrimaryButtonText=""
            CloseButtonText=""
            IsPrimaryButtonEnabled="False"
            DefaultButton="None"
            Width="714">

            <StackPanel Spacing="12">
                <TextBlock
                    Margin="0,0,0,15"
                    Text="Use throttle up/down to navigate. Press menu to close."
                    TextWrapping="Wrap"
                    Opacity="0.6" />

                <ItemsControl ItemsSource="{x:Bind ViewModel.Menu.MenuRows, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border
                                    Background="#FFE0E0E0"
                                    CornerRadius="10"
                                    Padding="22"
                                    Visibility="{Binding IsHighlighted, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <Grid ColumnSpacing="150">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Text="{Binding DisplayName}"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"/>

                                    <StackPanel 
                                        Grid.Column="1"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                        
                                        <ToggleButton 
                                            Width="150"
                                            IsHitTestVisible="False"                                            
                                            Content="{Binding DataContext.Menu.ToggleButtonText, ElementName=MenuPopup}"                                            
                                            BorderBrush="SlateGray"
                                            Background="White"
                                            CornerRadius="8"
                                            Visibility="{Binding IsToggleButton, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <Button 
                                            Width="150"
                                            IsHitTestVisible="False"
                                            Content="{Binding ButtonText}"                                            
                                            BorderBrush="SlateGray"
                                            Background="White"
                                            CornerRadius="8"
                                            Visibility="{Binding IsToggleButton, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                    Height="1"
                                    Background="#55000000"
                                    Margin="10,0,200,2"
                                    Visibility="{Binding IsHighlighted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>

                                <TextBlock
                                    Grid.Row="2"
                                    Text="{Binding Error}"
                                    Foreground="Red"
                                    FontSize="12"
                                    Margin="8,2,8,0"
                                    Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,40,0,0">

                    <Border
                        Background="#FFE0E0E0"
                        CornerRadius="10"
                        Padding="22"
                        Visibility="{x:Bind ViewModel.Menu.IsExitHighlighted, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <StackPanel VerticalAlignment="Center">
                        <Button
                            Content="Exit Application"
                            Width="180"
                            HorizontalAlignment="Center"
                            IsHitTestVisible="False"
                            BorderBrush="SlateGray"
                            Background="White"
                            CornerRadius="8"/>

                        <TextBlock
                            Text="{x:Bind ViewModel.Menu.ExitError, Mode=OneWay}"
                            Foreground="Red"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0"
                            Visibility="{x:Bind ViewModel.Menu.ExitError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ContentDialog>


        <!--UAV map-->
        <Grid x:Name="MapContainer" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
            <WebView
            x:Name="MapView"
            VerticalAlignment="Stretch"
            Visibility="Collapsed"
            d:Source="about:blank"
            d:DesignWidth="800"
            d:DesignHeight="600"
            d:DefaultBackgroundColor="Gray" />

            <Grid x:Name="MapFallback" Visibility="Visible" Background="DarkGray">
                <TextBlock 
                    Text="Map Service Unavailable"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"/>
            </Grid>
        </Grid>

        <!--Top bar overlay-->
        <Grid x:Name="AlertGrid"  Grid.Row="0" Grid.ColumnSpan="2" Height="56">
            <Grid.Background>
                <LinearGradientBrush x:Name="AlertBackground" StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="SlateGray" Offset="0.0"/>
                    <GradientStop Color="SlateGray" Offset="0.48"/>
                    <GradientStop Color="#002F4F4F" Offset="0.65"/>
                    <GradientStop Color="#002F4F4F" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Menu Icon with highlight-->
            <Border
                Grid.Column="0"
                Background="#55000000"
                Visibility="{Binding Menu.MenuActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Image 
                x:Name="MenuIcon"
                Grid.Column="0"
                Margin="11"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" 
                Source="Assets/MenuLogoWhite.png" 
                Stretch="Uniform" 
                Opacity="1"/>

            <!--Divider-->
            <Line 
                Grid.ColumnSpan="2" 
                X1="56" Y1="8" 
                X2="56" Y2="48" 
                Stroke="White" 
                StrokeThickness="1"/>

            <!--Flight warnings-->
            <TextBlock 
                Grid.Column="1" 
                VerticalAlignment="Center"
                Padding="15" 
                Text="{Binding Alerts.DisplayMessage}" 
                Foreground="White" 
                FontWeight="SemiBold" 
                FontSize="18"/>
        </Grid>

        <!--Left panel-->
        <Grid Grid.Row="1" Grid.Column="0" Padding="12, 7" RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="0.8*"/>
                <RowDefinition Height="1.6*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!--UAV Status-->
            <StackPanel Grid.Row="0" Padding="8">
                <TextBlock
                    Text="UAV Status"
                    HorizontalAlignment="Center"
                    TextDecorations="Underline"
                    FontSize="22"
                    FontWeight="Bold" />
            </StackPanel>

            <StackPanel Grid.Row="1" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--Flight Mode-->
                    <TextBlock 
                        Grid.Row="0" 
                        Grid.Column="0" 
                        Text="Flight Mode:"
                        FontSize="18"
                        FontWeight="SemiBold" />
                    <TextBlock 
                        Grid.Row="0" 
                        Grid.Column="1" 
                        Padding="20,0,0,10"
                        Text="{Binding Telemetry.FlightMode.DisplayText}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Left" />

                    <!--Connection-->
                    <TextBlock 
                        Grid.Row="1" 
                        Grid.Column="0" 
                        Text="GPS Connection:"
                        FontSize="18"
                        FontWeight="SemiBold"/>
                    <TextBlock 
                        Grid.Row="1" 
                        Grid.Column="1" 
                        Padding="20,0,0,10"
                        Text="{Binding Telemetry.GPS.DisplayText}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Left"/>
                </Grid>

            </StackPanel>

            <!--Telemetry-->
            <Border 
                Grid.Row="2" 
                Background="LightGray"
                Margin="20,0" 
                Padding="10" 
                CornerRadius="20" 
                BorderBrush="Black" 
                BorderThickness="2">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock 
                        Grid.Column="0"
                        Grid.Row="0"
                        Text="{Binding Telemetry.Battery.DisplayText}"
                        FontSize="16"
                        HorizontalAlignment="Center"/>

                    <TextBlock 
                        Grid.Column="1"
                        Grid.Row="0"
                        Text="{Binding Telemetry.Altitude.DisplayText}"
                        FontSize="16"
                        HorizontalAlignment="Center"/>

                    <TextBlock 
                        Grid.Column="0"
                        Grid.Row="1"
                        Margin="0,3,0,0"
                        Text="{Binding Telemetry.Speed.DisplayHorizontal}"
                        FontSize="16"
                        FontStyle="Italic"
                        HorizontalAlignment="Center"/>

                    <TextBlock 
                        Grid.Column="1"
                        Grid.Row="1"
                        Margin="0,3,0,0"
                        Text="{Binding Telemetry.Speed.DisplayVertical}"
                        FontSize="16"
                        FontStyle="Italic"
                        HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!--Divider-->
            <Line 
                Grid.Row="3"
                X1="0" Y1="0"
                X2="1" Y2="0"
                Margin="100,10,100,0"
                Stroke="Black"
                StrokeThickness="2"
                Stretch="Fill"
                VerticalAlignment="Stretch"/>

            <!--Flight Commands=-->
            <Border Grid.Row="4" Background="LightGray" Padding="8">
                <StackPanel>
                    <TextBlock
                        Padding="0,0,0,20"
                        Text="Flight Commands"
                        HorizontalAlignment="Center"
                        TextDecorations="Underline"
                        FontSize="22"
                        FontWeight="Bold" />

                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Height="35"
                            Margin="25,0"
                            Background="#55000000"
                            CornerRadius="10"
                            Visibility="{Binding FlightCommand.TakeoffActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock
                            Text="Takeoff"
                            FontSize="18"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>

                        <Rectangle 
                            Grid.Column="1" 
                            Height="25"
                            Width="1"
                            Fill="Black"
                            VerticalAlignment="Stretch"/>

                        <Border
                            Grid.Column="2"
                            Height="35"
                            Margin="25,0"
                            Background="#55000000"
                            CornerRadius="10"
                            Visibility="{Binding FlightCommand.LandActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock
                            Grid.Column="2"
                            Text="Land"
                            FontSize="18"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>

                        <Rectangle
                            Grid.Column="3" 
                            Height="25"
                            Width="1"
                            Fill="Black"
                            VerticalAlignment="Stretch"/>

                        <Border
                            Grid.Column="4"
                            Height="35"
                            Margin="25,0"
                            Background="#55000000"
                            CornerRadius="10"
                            Visibility="{Binding FlightCommand.StopActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock
                            Grid.Column="4"
                            Text="Stop"
                            FontSize="18"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

        </Grid>

        <Border 
            Grid.Row="2"
            Grid.ColumnSpan="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="SlateGray" Offset="0.0"/>
                            <GradientStop Color="SlateGray" Offset="0.48"/>
                            <GradientStop Color="AliceBlue" Offset="0.65"/>
                            <GradientStop Color="AliceBlue" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <TextBlock
                        Padding="20,0,0,0"
                        VerticalAlignment="Center"
                        Text="Event Log:"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="SemiBold"/>
                </Grid>

                <!-- Log content -->
                <ListView 
                    x:Name="EventLogList"
                    Grid.Row="1"
                    ItemsSource="{Binding EventLog}"
                    Background="AliceBlue"
                    Padding="10,4"
                    BorderThickness="0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionMode="None"
                    VerticalAlignment="Stretch">

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel VerticalAlignment="Bottom" 
                             ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="15,4"/>
                            <Setter Property="MinHeight" Value="0"/>

                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Setter Property="IsTabStop" Value="False"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Log entry row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding TimeDisplay}"
                                        FontSize="16"
                                        Foreground="DimGray"
                                        Margin="0,0,80,0" />

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding EventType}"
                                        FontSize="16" 
                                        Foreground="{Binding EventType, Converter={StaticResource EventTypeToColorConverter}}"/>

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding Message}"
                                        FontSize="16"
                                        TextWrapping="Wrap" />
                                </Grid>

                                <!-- Divider -->
                                <Border 
                                    Height="1"
                                    Background="#55000000"
                                    Margin="0,5,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>